# Database - PostgreSQL connection string (required for Vercel/production)
# Get a free PostgreSQL database from https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth - set to your deployed URL
NEXTAUTH_URL="https://your-app.vercel.app"

# NextAuth - generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"
