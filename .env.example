# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL via Neon (https://neon.tech)
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO GET YOUR DATABASE_URL (Neon step-by-step):
#
#   1. Open your Neon project dashboard → click "Connect" (or "Connection Details")
#   2. In the popup, make sure "Connection pooling" toggle is ON (green)
#   3. Copy the connection string shown — it will contain "-pooler" in the hostname
#   4. Paste it below as DATABASE_URL
#
# That's it — only ONE URL is required.  The build script automatically
# derives the direct connection URL from the pooler URL when running migrations.
#
DATABASE_URL="postgresql://neondb_owner:your-password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────────────────────────────────────────
#
# NEXTAUTH_URL  — your deployed Vercel URL, e.g. https://your-project.vercel.app
#   On Vercel this is auto-detected from VERCEL_URL when not set explicitly,
#   so you can leave it unset unless you have a custom domain.
#
# NEXTAUTH_SECRET — a random secret used to sign session cookies.
#   Generate one with:  openssl rand -base64 32
#
NEXTAUTH_URL="https://your-project.vercel.app"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"
