# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL (Neon recommended for Vercel deployments)
# ─────────────────────────────────────────────────────────────────────────────
# Get a free database at https://neon.tech
#
# IMPORTANT for Vercel / serverless:
#   • Use the POOLER (pgbouncer) connection string as DATABASE_URL.
#     It ends in "-pooler.<region>.aws.neon.tech".
#     This prevents "too many connections" errors on serverless.
#   • Set DIRECT_URL to the NON-pooler connection string.
#     Prisma uses DIRECT_URL for `prisma migrate deploy` (migrations require
#     a direct connection — pgbouncer does not support them).
#   • If you are NOT using Neon's pgbouncer, set both to the same URL.
#
# Pooler URL  (runtime queries, copy from Neon dashboard → Connection string → Pooled):
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30&pool_timeout=30"

# Direct URL  (migrations — copy from Neon dashboard → Connection string → Direct):
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────────────────────────────────────────
# Set to your deployed URL for production; use http://localhost:3000 locally.
# On Vercel this is auto-detected from VERCEL_URL when not set explicitly.
NEXTAUTH_URL="https://your-project.vercel.app"

# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"
