# -------------------------------------------------------
# Copy this file to .env for local development.
# On Vercel: set these in the project's Environment Variables tab.
# -------------------------------------------------------

# PostgreSQL connection string
# • Local dev example:  postgresql://postgres:password@localhost:5432/healthcare_dev
# • Vercel Postgres / Neon: copy the connection string from your Vercel or Neon dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# The public URL of this deployment (no trailing slash)
# • Local dev: http://localhost:3000
# • Vercel:    https://your-app.vercel.app   (must match the deployed URL exactly)
NEXTAUTH_URL="http://localhost:3000"

# Secret used to sign JWT session tokens — MUST be set in production.
# Generate a strong secret with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
